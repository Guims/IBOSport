<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape>
                    <stroke android:width="1.5dp" android:color="@color/white" />
                    <corners android:radius="@dimen/_120sdp" />
                    <solid android:color="@color/white_10" />
                </shape>
            </item>
            <item android:gravity="end|center" android:drawable="@drawable/ic_arrow_down" android:end="@dimen/_5sdp" />
            <item android:gravity="start|center" android:drawable="@drawable/filter_square" android:top="@dimen/_3sdp" android:bottom="@dimen/_3sdp" android:start="@dimen/_5sdp" />
        </layer-list>
    </item>
    <item android:state_focused="false">
        <layer-list>
            <item>
                <shape>
                    <stroke android:width="1.5dp" android:color="@color/white_30" />
                    <corners android:radius="@dimen/_120sdp" />
                    <solid android:color="@color/white_4" />
                </shape>
            </item>
            <item android:gravity="end|center" android:drawable="@drawable/ic_arrow_down" android:end="@dimen/_5sdp" />
            <item android:gravity="start|center" android:drawable="@drawable/filter_square" android:top="@dimen/_3sdp" android:bottom="@dimen/_3sdp" android:start="@dimen/_5sdp" />
        </layer-list>
    </item>
</selector>
